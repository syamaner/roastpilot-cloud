# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report
/test-results
/blob-report

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# snowflake/ tooling (schemachange is a Python tool, isolated from npm)
/snowflake/.venv
__pycache__/
*.pyc
.pytest_cache/
.coverage
htmlcov/

# F1-S9 slice 2 (issue #12): mutmut's own scratch sandbox (a copy of the
# mutated source + tests + pyproject.toml/config it runs each mutant
# against, plus its own stats output) -- entirely regenerated on every CI
# run, never committed.
/snowflake/mutants/
# The "List surviving mutant IDs" CI step's own output (claude-review
# finding, F1-S9 slice 2, issue #12, ready round) -- generated the same
# way locally as in CI, so it needs the same gitignore coverage as
# /snowflake/mutants/ above, not just that directory.
/snowflake/mutmut-survivors.txt

# factory scratch dirs (F1-S3, round 6 FIX 4): the implement job writes
# these into the SAME checkout the agent edits, so `git add -A` in the
# diff-capture step would otherwise stage them into the patch — and from
# there into a real product-branch commit. Never product content.
/issue-context
/patch-output
# F1-S10 slice 3: the publish job's own checkout, where the downloaded
# implement-agent-transcript artifact lands before applyPatchAndPush's
# `git add -A` — same reasoning as the two above.
/transcript-output
